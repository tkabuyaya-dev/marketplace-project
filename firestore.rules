// ============================================================
// NUNULIA — Firestore Security Rules (Niveau Fintech)
// Version: 2.0
// Déploiement: firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // FONCTIONS UTILITAIRES
    // ─────────────────────────────────────────────────────────

    // Vérifie si l'utilisateur est authentifié
    function isAuth() {
      return request.auth != null;
    }

    // Vérifie si c'est l'utilisateur lui-même
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Récupère le document utilisateur depuis Firestore.
    // Réservé aux checks où le JWT ne suffit pas :
    //   - canCreateProduct() : maxProducts / productCount / lastProductCreatedAt (compteurs volatils)
    //   - isNotSuspendedStrict() : anti-TTL JWT sur writes critiques (products)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Rôle lu depuis les custom claims Firebase Auth (JWT).
    // Synchronisé par la CF onUserRoleWrite à chaque changement de users/{uid}.role,
    // propagé au client via claimsUpdatedAt + getIdToken(true). TTL ~1h max.
    function isAdmin() {
      return isAuth() && request.auth.token.get('role', '') == 'admin';
    }

    function isSeller() {
      return isAuth() && (
        request.auth.token.get('role', '') == 'seller'
        || request.auth.token.get('role', '') == 'admin'
      );
    }

    // Suspension — version rapide (JWT, TTL ~1h). Utilisée par défaut sur tous les
    // writes non critiques (reports, reviews, subscriptionRequests, boostRequests,
    // buyerRequestContacts, users/self-update).
    function isNotSuspended() {
      return isAuth() && request.auth.token.get('suspended', false) == false;
    }

    // Suspension — version stricte (lecture Firestore, effet immédiat, 1 read extra).
    // Utilisée sur les writes critiques où un décalage TTL JWT serait dangereux :
    // création et édition de produits.
    function isNotSuspendedStrict() {
      return isAuth() && getUserData().get('isSuspended', false) == false;
    }

    // Valide qu'un string n'est pas vide et pas trop long
    function validString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    // Valide un prix (positif, raisonnable)
    function validPrice(price) {
      return price is number && price >= 0 && price <= 999999999;
    }

    // ── Subscription Enforcement (server-side) ──

    // Check if seller's subscription allows creating products + rate limiting
    function canCreateProduct() {
      let seller = getUserData();
      let maxProducts = seller.get('sellerDetails', {}).get('maxProducts', 5);
      let productCount = seller.get('productCount', 0);
      let expiresAt = seller.get('sellerDetails', {}).get('subscriptionExpiresAt', null);
      let isPaid = maxProducts > 5;

      // Burst protection (server-enforced): 20-second cooldown between creations.
      // lastProductCreatedAt is written by addProduct() after each successful create.
      // This prevents direct API abuse even if client-side checks are bypassed.
      let lastCreate = seller.get('lastProductCreatedAt', 0);
      let cooldownOk = lastCreate < request.time.toMillis() - 20000;

      // Rule 1: If paid tier and expired → enforce free tier limit (5)
      // Rule 2: If within limits → allow
      // Rule 3: Cooldown must be respected regardless of tier
      return cooldownOk && (
        (isPaid && expiresAt != null && expiresAt < request.time.toMillis())
          ? productCount < 5                // Expired → free tier limit
          : productCount < maxProducts      // Active → tier limit
      );
    }

    // ─────────────────────────────────────────────────────────
    // USERS — Profils publics, écriture = soi-même uniquement
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Lecture: tout le monde peut voir un profil (marketplace public)
      allow read: if true;

      // Création: l'utilisateur crée son propre profil à l'inscription
      allow create: if isOwner(userId)
        && validString(request.resource.data.name, 100)
        && request.resource.data.role == 'buyer' // Rôle initial = buyer toujours
        && request.resource.data.keys().hasAll(['name', 'email', 'role', 'joinDate']);

      // Mise à jour: soi-même avec restrictions, ou admin sans restriction
      allow update: if isAdmin()
        || (isOwner(userId) && isNotSuspended() && (
          // Cas 1: Mise à jour profil normale.
          // Champs verrouillés admin-only :
          //   - role, isVerified (historiques)
          //   - verificationTier : source canonique du niveau de confiance
          //   - trustScore : score calculé, jamais auto-déclaré
          //   - verifiedAt : timestamp de vérification
          //   - verificationMethod : méthode utilisée par l'admin
          // + champs d'abonnement (sellerDetails.maxProducts/subscriptionExpiresAt/tierLabel/verifiedAt/verificationMethod)
          (
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'isVerified', 'verificationTier', 'trustScore', 'verifiedAt', 'verificationMethod'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sellerDetails'])
              || (
                request.resource.data.get('sellerDetails', {}).get('maxProducts', 5) == resource.data.get('sellerDetails', {}).get('maxProducts', 5)
                && request.resource.data.get('sellerDetails', {}).get('subscriptionExpiresAt', null) == resource.data.get('sellerDetails', {}).get('subscriptionExpiresAt', null)
                && request.resource.data.get('sellerDetails', {}).get('tierLabel', 'Gratuit') == resource.data.get('sellerDetails', {}).get('tierLabel', 'Gratuit')
                && request.resource.data.get('sellerDetails', {}).get('verifiedAt', null) == resource.data.get('sellerDetails', {}).get('verifiedAt', null)
                && request.resource.data.get('sellerDetails', {}).get('verificationMethod', null) == resource.data.get('sellerDetails', {}).get('verificationMethod', null)
              )
            )
          )
          ||
          // Cas 2: Inscription vendeur — buyer → seller uniquement (isVerified/tier restent non vérifiés)
          (
            resource.data.role == 'buyer'
            && request.resource.data.role == 'seller'
            && request.resource.data.get('isVerified', false) == false
            && request.resource.data.get('verificationTier', 'none') == 'none'
            && request.resource.data.keys().hasAll(['sellerDetails'])
          )
        ));

      // Suppression: admin uniquement
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // PRODUCTS — Marketplace principal
    // ─────────────────────────────────────────────────────────
    match /products/{productId} {
      // Lecture: produits approuvés = public | propres produits = vendeur | tout = admin
      allow read: if resource.data.status == 'approved'
        || (isAuth() && resource.data.sellerId == request.auth.uid)
        || isAdmin();

      // Création: vendeur authentifié, non suspendu (strict Firestore), abonnement valide, champs validés
      allow create: if isSeller()
        && isNotSuspendedStrict()
        && canCreateProduct()
        && request.resource.data.sellerId == request.auth.uid
        && validString(request.resource.data.title, 200)
        && validString(request.resource.data.description, 5000)
        && validPrice(request.resource.data.price)
        && request.resource.data.status == 'pending' // Status initial = pending toujours
        && request.resource.data.views == 0
        && request.resource.data.likesCount == 0
        && request.resource.data.reports == 0
        // createdAt doit être le timestamp serveur (empêche toute falsification de date)
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasAll(['title', 'titleLower', 'price', 'description', 'sellerId', 'category', 'status', 'createdAt'])
        && (request.resource.data.get('marketplace', null) == null
            || request.resource.data.marketplace in ['bata', 'kamenge', 'centre-ville', 'kinama', 'autres']);

      // Mise à jour: vendeur (son produit, champs limités) ou admin (tout)
      // ou tout utilisateur auth pour incrémenter views/likesCount
      allow update: if isAdmin()
        || (isAuth()
          && resource.data.sellerId == request.auth.uid
          && isNotSuspendedStrict()
          // Vendeur ne peut PAS changer: status, views, likesCount, reports, sellerId
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['status', 'sellerId', 'reports', 'isPromoted']))
        || (isAuth()
          // Vendeur peut re-soumettre un produit rejeté (status: rejected → pending), max 3 fois
          && resource.data.sellerId == request.auth.uid
          && isNotSuspendedStrict()
          && resource.data.status == 'rejected'
          && request.resource.data.status == 'pending'
          && resource.data.get('resubmitCount', 0) < 3
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'resubmittedAt', 'resubmitCount']))
        || (isAuth()
          // Vendeur peut éditer le contenu ET re-soumettre un produit rejeté en 1 write atomique.
          // Capacités équivalentes à (branche edit) + (branche resubmit) combinées, mais sans
          // risque de désynchronisation entre 2 writes séparés.
          && resource.data.sellerId == request.auth.uid
          && isNotSuspendedStrict()
          && resource.data.status == 'rejected'
          && request.resource.data.status == 'pending'
          && resource.data.get('resubmitCount', 0) < 3
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['sellerId', 'reports', 'isPromoted', 'createdAt']))
        || (isAuth()
          // Tout utilisateur auth peut incrémenter/décrémenter views ou likesCount de 1 max
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likesCount'])
          && (request.resource.data.views == resource.data.views || request.resource.data.views == resource.data.views + 1)
          && (request.resource.data.likesCount == resource.data.likesCount
              || request.resource.data.likesCount == resource.data.likesCount + 1
              || request.resource.data.likesCount == resource.data.likesCount - 1));

      // Suppression: vendeur (son produit) ou admin
      allow delete: if (isAuth() && resource.data.sellerId == request.auth.uid) || isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // LIKES — Collection plate pour éviter les tableaux géants
    // Structure: /likes/{productId_userId}
    // ─────────────────────────────────────────────────────────
    match /likes/{likeId} {
      // Lecture: pour vérifier si un user a liké
      allow read: if isAuth();

      // Création/suppression: seulement son propre like
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['productId', 'userId', 'createdAt']);

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────
    // CONVERSATIONS & MESSAGES — SUPPRIMÉS (A5, 2026-04-15)
    // Le chat P2P a été retiré du produit ; aucune route front ne
    // lit/écrit `conversations/*` (grep = 0 référence dans le code).
    // Les rules ont été supprimées → la deny-all par défaut en fin de
    // fichier bloque tout accès résiduel. La collection Firestore peut
    // être purgée via `firebase firestore:delete --recursive conversations`
    // quand l'opérateur confirme qu'il n'y a plus de données utiles.
    // ─────────────────────────────────────────────────────────

    // ─────────────────────────────────────────────────────────
    // CATEGORIES — Gérées par admin uniquement
    // ─────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true; // Public (affiché sur la home)
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // SUBSCRIPTION TIERS — Config admin
    // ─────────────────────────────────────────────────────────
    match /subscriptionTiers/{tierId} {
      allow read: if true; // Vendeurs doivent voir les forfaits
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // COUNTRIES — Config admin
    // ─────────────────────────────────────────────────────────
    match /countries/{countryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // BANNERS — Carrousel dynamique (admin gère, public lit)
    // ─────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true; // Public (affiché sur la home)
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // CURRENCIES — Devises (admin gère, public lit)
    // ─────────────────────────────────────────────────────────
    match /currencies/{currencyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // MARKETPLACES — Marchés physiques (admin gère, public lit)
    // ─────────────────────────────────────────────────────────
    match /marketplaces/{marketplaceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // REPORTS — Signalements utilisateurs
    // ─────────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();

      // Création: utilisateur authentifié
      allow create: if isAuth()
        && isNotSuspended()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasAll(['productId', 'reporterId', 'reason', 'createdAt']);

      // Pas de modification/suppression par les users
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // NOTIFICATIONS — Système de notifications in-app
    // ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Lecture: uniquement ses propres notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;

      // Création: admin peut créer pour n'importe qui, user auth seulement pour notifs message destinées à autrui
      allow create: if isAdmin()
        || (isAuth()
          && request.resource.data.type == 'new_message'
          && request.resource.data.userId is string
          && request.resource.data.userId != request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && request.resource.data.read == false);

      // Mise à jour: l'utilisateur peut seulement marquer comme lu
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Suppression: admin ou propriétaire
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────
    // REVIEWS — Avis clients avec photos
    // ─────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isAuth()
        && isNotSuspended()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && validString(request.resource.data.comment, 1000)
        && request.resource.data.keys().hasAll(['userId', 'userName', 'productId', 'rating', 'comment', 'createdAt']);

      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // USER ACTIVITY — Tracking pour recommandations
    // ─────────────────────────────────────────────────────────
    match /userActivity/{activityId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.action in ['view', 'like', 'contact']
        && request.resource.data.keys().hasAll(['userId', 'productId', 'category', 'action', 'createdAt']);

      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // SUBSCRIPTION REQUESTS — Demandes d'abonnement
    // ─────────────────────────────────────────────────────────
    match /subscriptionRequests/{requestId} {
      // Lecture: admin voit tout, seller voit ses propres demandes
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);

      // Création: vendeur authentifié crée sa propre demande
      allow create: if isAuth()
        && isNotSuspended()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['userId', 'sellerName', 'countryId', 'planId', 'planLabel', 'amount', 'currency', 'status', 'maxProducts']);

      // Update: admin peut tout modifier, seller peut seulement confirmer paiement
      allow update: if isAdmin()
        || (isAuth()
          && resource.data.userId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending_validation'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'transactionRef', 'updatedAt']));

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // SUBSCRIPTION PRICING — Prix par pays (admin gère, public lit)
    // ─────────────────────────────────────────────────────────
    match /subscriptionPricing/{countryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // AUDIT LOGS — Lecture seule admin (écriture via Cloud Functions)
    // ─────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Uniquement via Cloud Functions (admin SDK)
    }

    // ─────────────────────────────────────────────────────────
    // BLOCKLIST — IPs/UIDs bannis (lecture via Cloud Functions)
    // ─────────────────────────────────────────────────────────
    match /blocklist/{entryId} {
      allow read, write: if false; // Géré uniquement via Admin SDK
    }

    // ─────────────────────────────────────────────────────────
    // APP SETTINGS (langues, config globale)
    // ─────────────────────────────────────────────────────────
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // BUYER REQUESTS — Fonctionnalité "Je Cherche"
    // buyerRequests: acheteurs postent leurs besoins
    // buyerRequestContacts: tracking des clics WhatsApp vendeurs
    // ─────────────────────────────────────────────────────────

    // Valide le format WhatsApp : chiffres uniquement après le + optionnel, 7-15 chiffres
    function validWhatsapp(phone) {
      return phone is string
        && phone.size() >= 7
        && phone.size() <= 20
        && (phone.matches('^\\+[0-9]{7,15}$') || phone.matches('^[0-9]{7,15}$'));
    }

    match /buyerRequests/{requestId} {
      // Lecture: publique (vérif rate-limit acheteur anonyme + navigation vendeurs)
      allow read: if true;

      // Création: tout le monde (acheteurs anonymes supportés), champs validés
      // Protection: timestamps vérifiés côté serveur, format WhatsApp validé
      //
      // NOTE: on utilise `is number` (pas `is int`) car le SDK Firebase JS peut encoder
      // les grands entiers (Date.now() ≈ 1.7×10¹²) tantôt en integer_value, tantôt en
      // double_value selon la plateforme (iOS Safari notamment). La vérification de
      // plage (>= / <=) est la vraie protection sécuritaire — le type exact importe peu.
      allow create: if validString(request.resource.data.title, 200)
        && validWhatsapp(request.resource.data.whatsapp)
        && validString(request.resource.data.buyerName, 100)
        && request.resource.data.status == 'active'
        && request.resource.data.viewCount == 0
        && request.resource.data.contactCount == 0
        // createdAt : nombre de ms — tolérance ±5 min (horloge décalée Android/iOS)
        && request.resource.data.createdAt is number
        && request.resource.data.createdAt >= request.time.toMillis() - 300000
        && request.resource.data.createdAt <= request.time.toMillis() + 300000
        // expiresAt : entre 1 et 8 jours après createdAt
        && request.resource.data.expiresAt is number
        && request.resource.data.expiresAt > request.resource.data.createdAt
        && request.resource.data.expiresAt <= request.resource.data.createdAt + 691200000
        && request.resource.data.keys().hasAll([
            'title', 'whatsapp', 'buyerName', 'countryId', 'province', 'city',
            'status', 'createdAt', 'expiresAt', 'viewCount', 'contactCount'
          ]);

      // Mise à jour:
      //   - Admin : tout
      //   - Propriétaire connecté : peut marquer 'fulfilled' ou 'deleted'
      //   - Vendeur connecté : peut incrémenter viewCount / contactCount de 1
      allow update: if isAdmin()
        || (isAuth()
            && resource.data.buyerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && request.resource.data.status in ['fulfilled', 'deleted'])
        || (isAuth()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['viewCount', 'contactCount'])
            && (request.resource.data.viewCount == resource.data.viewCount
                || request.resource.data.viewCount == resource.data.viewCount + 1)
            && (request.resource.data.contactCount == resource.data.contactCount
                || request.resource.data.contactCount == resource.data.contactCount + 1));

      // Suppression physique: admin uniquement (soft-delete via update)
      allow delete: if isAdmin();
    }

    match /buyerRequestContacts/{contactId} {
      // Lecture: admin ou le vendeur lui-même
      allow read: if isAdmin()
        || (isAuth() && resource.data.sellerId == request.auth.uid);

      // Création: vendeur connecté, non suspendu, tracking de son propre clic WA
      allow create: if isAuth()
        && isNotSuspended()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.keys().hasAll([
            'requestId', 'sellerId', 'sellerTierId', 'timestamp'
          ]);

      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // BOOST REQUESTS — Demandes de mise en avant payante
    // ─────────────────────────────────────────────────────────
    match /boostRequests/{requestId} {
      // Lecture: admin voit tout, vendeur voit ses propres demandes
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);

      // Création: vendeur authentifié, non suspendu, crée pour lui-même
      allow create: if isAuth()
        && isNotSuspended()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && validString(request.resource.data.productId, 100)
        && validString(request.resource.data.productTitle, 200)
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.keys().hasAll([
            'userId', 'sellerName', 'countryId', 'productId', 'productTitle',
            'amount', 'currency', 'status', 'createdAt', 'updatedAt'
          ]);

      // Update: admin peut tout modifier, vendeur peut seulement confirmer paiement
      allow update: if isAdmin()
        || (isAuth()
          && resource.data.userId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending_validation'
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['status', 'transactionRef', 'updatedAt']));

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // BOOST PRICING — Prix boost par pays (admin gère, public lit)
    // ─────────────────────────────────────────────────────────
    match /boostPricing/{countryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // DENY ALL — Toute collection non listée est bloquée par défaut
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
